{
    "name": "testing-twigs",
    "version": "0.3.0",
    "description": "Twigs React Native component library",
    "main": "./lib/commonjs/index.js",
    "module": "./lib/module/index.js",
    "types": "./lib/typescript/index.d.ts",
    "react-native": "./lib/commonjs/index.js",
    "source": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./lib/typescript/index.d.ts",
            "import": "./lib/module/index.js",
            "require": "./lib/commonjs/index.js"
        },
        "./theme": {
            "types": "./lib/typescript/theme/index.d.ts",
            "import": "./lib/module/theme/index.js",
            "require": "./lib/commonjs/theme/index.js"
        }
    },
    "files": [
        "lib",
        "!**/__tests__",
        "!**/__fixtures__",
        "!**/__mocks__",
        "!**/*.stories.*"
    ],
    "scripts": {
        "build": "bob build",
        "prepack": "bob build",
        "example": "npm start --prefix example",
        "example:ios": "npm run ios --prefix example",
        "example:android": "npm run android --prefix example",
        "lint": "eslint src/**/*.{ts,tsx}",
        "lint:fix": "eslint src/**/*.{ts,tsx} --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
        "format:check": "prettier --check \"src/**/*.{ts,tsx,json}\"",
        "test": "jest",
        "test:watch": "jest --watch",
        "release": "release-it",
        "release:dry": "release-it --dry-run"
    },
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "keywords": [
        "react-native",
        "twigs-mobile",
        "ui",
        "component-library"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/krishnan-456/twigs-mobile-internal.git"
    },
    "homepage": "https://github.com/krishnan-456/twigs-mobile-internal#readme",
    "bugs": {
        "url": "https://github.com/krishnan-456/twigs-mobile-internal/issues"
    },
    "author": "SurveySparrow",
    "license": "MIT",
    "engines": {
        "node": ">=18.20.1"
    },
    "peerDependencies": {
        "@gorhom/bottom-sheet": ">=5.0.0",
        "react": ">=18.0.0",
        "react-native": ">=0.71.0",
        "react-native-gesture-handler": ">=2.0.0",
        "react-native-reanimated": ">=3.0.0",
        "react-native-svg": ">=13.0.0"
    },
    "devDependencies": {
        "@gorhom/bottom-sheet": "^5.2.6",
        "@react-native/babel-preset": "^0.83.1",
        "@release-it/conventional-changelog": "^10.0.5",
        "@testing-library/jest-native": "^5.4.3",
        "@testing-library/react-native": "^13.3.3",
        "@types/jest": "^30.0.0",
        "@types/react": "^18.2.48",
        "@types/react-native": "^0.73.0",
        "@types/react-test-renderer": "18",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "eslint": "^8.56.0",
        "eslint-plugin-react": "^7.33.2",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-native": "^4.1.0",
        "husky": "^9.0.0",
        "jest": "^30.2.0",
        "lint-staged": "^15.2.0",
        "prettier": "^3.2.0",
        "react": "^18.3.1",
        "react-native": "^0.76.0",
        "react-native-builder-bob": "^0.30.2",
        "react-native-gesture-handler": "~2.20.2",
        "react-native-reanimated": "~3.16.1",
        "react-native-svg": "~15.8.0",
        "react-test-renderer": "18.3.1",
        "release-it": "^19.2.4",
        "ts-jest": "^29.4.6",
        "typescript": "^5.3.3"
    },
    "lint-staged": {
        "src/**/*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "src/**/*.{json,md}": [
            "prettier --write"
        ]
    },
    "workspaces": [
        "example"
    ],
    "react-native-builder-bob": {
        "source": "src",
        "output": "lib",
        "exclude": [
            "**/{__tests__,__fixtures__,__mocks__}/**",
            "**/*.stories.{ts,tsx}"
        ],
        "targets": [
            [
                "commonjs",
                {
                    "configFile": true
                }
            ],
            [
                "module",
                {
                    "configFile": true
                }
            ],
            "typescript"
        ]
    }
}
